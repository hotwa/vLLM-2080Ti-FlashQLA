# Hugging Face token. Leave empty for public repos.
HF_TOKEN=

# Server runtime.
HOST=0.0.0.0
PORT=8080
MODEL_PATH=./models/Qwopus-GLM-18B-Healed-Q4_K_M.gguf
MODEL_NAME=
API_KEY=
CTX_SIZE=262144
GPU_LAYERS=999
BATCH_SIZE=2048
UBATCH_SIZE=512
THREADS=8
N_PARALLEL=1
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0
FLASH_ATTN=1
JINJA=1
CHAT_TEMPLATE_FILE=
NO_CONTEXT_SHIFT=1
NO_MMAP=1

# Optional tuning.
# SPLIT_MODE=none
# TENSOR_SPLIT=
# CUDA_VISIBLE_DEVICES=all

# Build/runtime defaults.
CUDA_VERSION=12.8.1
CMAKE_CUDA_ARCHITECTURES=
IK_LLAMA_REPO=https://github.com/ikawrakow/ik_llama.cpp
IK_LLAMA_REF=main

# Hugging Face model source.
MODEL_REPO=Jackrong/Qwopus-GLM-18B-Merged-GGUF
