{%- set image_count = namespace(value=0) -%}
{%- set video_count = namespace(value=0) -%}
{%- set TOOL_RESPONSE_MAX_LEN = 10000 -%}

{%- macro safe_text(value) -%}
    {%- if value is string -%}
        {{- value -}}
    {%- elif value is number -%}
        {{- value | string -}}
    {%- elif value is boolean -%}
        {{- value | string -}}
    {%- elif value is none or value is undefined -%}
        {{- '' -}}
    {%- elif value is mapping -%}
        {%- if value.text is defined and value.text is not none -%}
            {{- value.text | string -}}
        {%- elif value.content is defined and value.content is not none -%}
            {{- safe_text(value.content) -}}
        {%- else -%}
            {{- value | tojson -}}
        {%- endif -%}
    {%- elif value is iterable -%}
        {{- value | tojson -}}
    {%- else -%}
        {{- value | string -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro render_content(content, do_vision_count=false, is_system_content=false) -%}
    {%- if content is string -%}
        {{- content -}}

    {%- elif content is none or content is undefined -%}
        {{- '' -}}

    {%- elif content is mapping -%}
        {%- if content.text is defined and content.text is not none -%}
            {{- content.text | string -}}
        {%- elif content.content is defined and content.content is not none -%}
            {{- safe_text(content.content) -}}
        {%- else -%}
            {{- content | tojson -}}
        {%- endif -%}

    {%- elif content is iterable and content is not mapping -%}
        {%- for item in content -%}
            {%- if item is string -%}
                {{- item -}}

            {%- elif item is mapping -%}
                {%- set item_type = item.type if item.type is defined else none -%}

                {%- if ('image' in item) or ('image_url' in item) or item_type == 'image' or item_type == 'input_image' -%}
                    {%- if not is_system_content -%}
                        {%- if do_vision_count -%}
                            {%- set image_count.value = image_count.value + 1 -%}
                        {%- endif -%}
                        {{- '<|vision_start|><|image_pad|><|vision_end|>' -}}
                    {%- endif -%}

                {%- elif ('video' in item) or item_type == 'video' or item_type == 'input_video' -%}
                    {%- if not is_system_content -%}
                        {%- if do_vision_count -%}
                            {%- set video_count.value = video_count.value + 1 -%}
                        {%- endif -%}
                        {{- '<|vision_start|><|video_pad|><|vision_end|>' -}}
                    {%- endif -%}

                {%- elif item.text is defined and item.text is not none -%}
                    {{- item.text | string -}}
                {%- elif item.content is defined and item.content is not none -%}
                    {{- safe_text(item.content) -}}
                {%- elif item.input_text is defined and item.input_text is not none -%}
                    {{- item.input_text | string -}}
                {%- elif item_type == 'text' and item.text is defined and item.text is not none -%}
                    {{- item.text | string -}}
                {%- elif item_type == 'output_text' and item.text is defined and item.text is not none -%}
                    {{- item.text | string -}}
                {%- else -%}
                    {{- '' -}}
                {%- endif -%}

            {%- else -%}
                {{- safe_text(item) -}}
            {%- endif -%}
        {%- endfor -%}

    {%- else -%}
        {{- safe_text(content) -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro render_tool_call_xml(tc) -%}
    {%- if tc.function is defined -%}
        {%- set fn = tc.function -%}
    {%- else -%}
        {%- set fn = tc -%}
    {%- endif -%}
<tool_call>
<function={{ fn.name if fn.name is defined else 'unknown_tool' }}>
{%- if fn.arguments is mapping -%}
    {%- for k, v in fn.arguments.items() -%}
<parameter={{ k }}>
{%- if v is mapping or (v is sequence and v is not string) -%}
{{ v | tojson }}
{%- else -%}
{{ v | string }}
{%- endif -%}
</parameter>
    {%- endfor -%}
{%- elif fn.arguments is string -%}
<parameter=arguments>
{{ fn.arguments }}
</parameter>
{%- elif fn.arguments is defined and fn.arguments is not none -%}
<parameter=arguments>
{{ fn.arguments | tojson }}
</parameter>
{%- endif -%}
</function>
</tool_call>
{%- endmacro -%}

{%- if not messages or messages | length == 0 -%}
{{- raise_exception('No messages provided.') -}}
{%- endif -%}

{%- set ns = namespace(system_parts=[]) -%}
{%- for message in messages -%}
    {%- if message.role == 'system' or message.role == 'developer' -%}
        {%- set part = render_content(message.content, false, true) | trim -%}
        {%- if part -%}
            {%- set ns.system_parts = ns.system_parts + [part] -%}
        {%- endif -%}
    {%- endif -%}
{%- endfor -%}

{%- set protocol_block -%}
You are a coding and multimodal assistant for OpenCode-style agent workflows.

CRITICAL OUTPUT RULES:

1. Never reveal hidden reasoning, chain-of-thought, or internal analysis to the user.
2. The serving stack may disable explicit thinking output by default. Do not rely on visible <think> blocks.
3. Never output <tool_code>.
4. If tools are available, use ONLY the tools listed in <tools>.
5. When you need to call tools, output one or more XML tool-call blocks in exactly this form:

<tool_call>
<function=TOOL_NAME>
<parameter=ARG_NAME>
ARG_VALUE
</parameter>
</function>
</tool_call>

6. During a tool-calling turn, do not output explanatory text, markdown fences, or commentary before, between, or after tool-call XML blocks, except that multiple <tool_call> blocks must be separated by exactly one blank line.
7. After tool results are returned, continue the task normally and provide a direct final answer unless another tool call is still necessary.
8. Do not stop after tools complete. If the task has enough information, provide the final answer.
9. Do not output JSON tool calls.
10. If multiple tool calls are needed, output multiple <tool_call> blocks consecutively, separated by exactly one blank line.
11. If no tool is needed, answer normally in plain text.
12. For the bash tool, always provide BOTH:
    - <parameter=command>
    - <parameter=description>
13. The description must briefly explain the purpose of the command.
14. For image or video understanding requests, answer directly from the visual input when no tool is needed.
15. Arguments may be provided either as structured parameters or as a single JSON string wrapped inside:
<parameter=arguments>
{"key":"value"}
</parameter>
Both forms are valid.
16. If a tool call is produced, ensure the XML is well-formed and complete.
17. When tool results have already been provided and no further tool is needed, do not emit another tool call. Give the final answer in plain text.

{%- if tools and tools is iterable and tools is not mapping %}

# Tools

You have access to the following functions:

<tools>
{%- for tool in tools %}
{{ tool | tojson }}
{%- endfor %}
</tools>
{%- endif %}
{%- endset -%}

