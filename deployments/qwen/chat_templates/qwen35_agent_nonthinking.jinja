{# ============================================================
  qwen35_agent_toolcall_text.jinja

  Purpose:
  - Stable agent-oriented template for Qwen3.5 on SGLang
  - OpenCode / OpenClaw friendly
  - Hoist system + developer into one leading system block
  - Strongly discourage thinking output
  - Strongly enforce ONE textual tool protocol:
      <tool_call>{"name":"...","arguments":{...}}</tool_call>
  - No native parser dependency
============================================================ #}

{%- if not messages or messages | length == 0 -%}
{{- raise_exception("No messages provided.") -}}
{%- endif -%}

{%- macro extract_text(content, allow_media=false, is_system=false) -%}
    {%- if content is string -%}
        {{- content -}}
    {%- elif content is none or content is undefined -%}
        {{- "" -}}
    {%- elif content is iterable and content is not mapping -%}
        {%- for item in content -%}
            {%- if item is mapping -%}
                {%- if "text" in item -%}
                    {{- item.text -}}
                {%- elif item.type is defined and item.type == "text" and item.text is defined -%}
                    {{- item.text -}}
                {%- elif ("image" in item or "image_url" in item or (item.type is defined and item.type == "image")) -%}
                    {%- if is_system -%}
                        {{- raise_exception("System/developer message cannot contain images.") -}}
                    {%- endif -%}
                    {%- if allow_media -%}
                        {{- "<|vision_start|><|image_pad|><|vision_end|>" -}}
                    {%- endif -%}
                {%- elif ("video" in item or (item.type is defined and item.type == "video")) -%}
                    {%- if is_system -%}
                        {{- raise_exception("System/developer message cannot contain videos.") -}}
                    {%- endif -%}
                    {%- if allow_media -%}
                        {{- "<|vision_start|><|video_pad|><|vision_end|>" -}}
                    {%- endif -%}
                {%- endif -%}
            {%- endif -%}
        {%- endfor -%}
    {%- else -%}
        {{- "" -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro strip_think(text) -%}
    {%- if text is string and "<think>" in text and "</think>" in text -%}
        {{- text.split("</think>", 1)[1].lstrip("\n") -}}
    {%- elif text is string -%}
        {{- text -}}
    {%- else -%}
        {{- "" -}}
    {%- endif -%}
{%- endmacro -%}

{# ------------------------------------------------------------
   Hoist all system + developer into one leading system block
------------------------------------------------------------ #}
{%- set ns = namespace(system_parts=[]) -%}
{%- for message in messages -%}
    {%- if message.role == "system" or message.role == "developer" -%}
        {%- set part = extract_text(message.content, false, true) | trim -%}
        {%- if part -%}
            {%- set ns.system_parts = ns.system_parts + [part] -%}
        {%- endif -%}
    {%- endif -%}
{%- endfor -%}

{%- set tool_protocol_block -%}
You are an agent-oriented coding assistant.

Follow these rules strictly:

1. Do NOT output <think>, </think>, chain-of-thought, hidden reasoning, or internal analysis.
2. Do NOT output <tool_code>.
3. Do NOT output OpenAI-style tool_calls JSON objects directly.
4. When you need to call a tool, output EXACTLY one or more blocks in this format:

<tool_call>{"name":"TOOL_NAME","arguments":{"key":"value"}}</tool_call>

5. The JSON inside <tool_call> must be valid JSON.
6. Use double quotes in JSON.
7. Do not wrap tool calls in markdown code fences.
8. Do not add any explanation after a tool call.
9. If multiple tool calls are needed, output multiple <tool_call>...</tool_call> blocks and nothing else after the final tool call.
10. If no tool is needed, answer normally in plain text.
11. Never output empty <think></think>.
12. Never output <tool_code>...</tool_code>.

Valid examples:

<tool_call>{"name":"read_file","arguments":{"path":"src/main.py"}}</tool_call>

<tool_call>{"name":"read_file","arguments":{"path":"a.py"}}</tool_call>
<tool_call>{"name":"read_file","arguments":{"path":"b.py"}}</tool_call>

If you answer normally, provide only the final user-facing answer, with no hidden reasoning.
{%- endset -%}

{%- set merged_system = (ns.system_parts | join("\n\n")) | trim -%}
{%- if merged_system -%}
    {%- set merged_system = tool_protocol_block | trim + "\n\n" + merged_system -%}
{%- else -%}
    {%- set merged_system = tool_protocol_block | trim -%}
{%- endif -%}

<|im_start|>system
{{ merged_system }}
<|im_end|>

{# ------------------------------------------------------------
   Render remaining conversation
------------------------------------------------------------ #}
{%- set body = namespace(count=0) -%}
{%- for message in messages -%}
    {%- if message.role == "system" or message.role == "developer" -%}
        {# already hoisted #}

    {%- elif message.role == "user" -%}
        {%- set content = extract_text(message.content, true, false) | trim -%}
        {%- if content -%}
<|im_start|>user
{{ content }}
<|im_end|>
            {%- set body.count = body.count + 1 -%}
        {%- endif -%}

    {%- elif message.role == "assistant" -%}
        {# ignore reasoning_content; strip any prior think tags from content #}
        {%- set content = extract_text(message.content, true, false) -%}
        {%- set content = strip_think(content) | trim -%}
        {%- if content -%}
<|im_start|>assistant
{{ content }}
<|im_end|>
            {%- set body.count = body.count + 1 -%}
        {%- endif -%}

    {%- elif message.role == "tool" -%}
        {%- set content = extract_text(message.content, true, false) | trim -%}
        {%- if content -%}
<|im_start|>user
<tool_response>
{{ content }}
</tool_response>
<|im_end|>
            {%- set body.count = body.count + 1 -%}
        {%- endif -%}

    {%- else -%}
        {{- raise_exception("Unexpected message role: " + message.role) -}}
    {%- endif -%}
{%- endfor -%}

{%- if body.count == 0 -%}
{{- raise_exception("Rendered prompt body is empty.") -}}
{%- endif -%}

{%- if add_generation_prompt -%}
<|im_start|>assistant
{%- endif -%}