# Hugging Face credentials.
# Leave blank if the model repo is public and no auth is required.
HF_TOKEN=
HUGGINGFACE_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Project and model selection.
MODEL_REPO=unsloth/Qwen3.6-35B-A3B-GGUF
MODEL_FILE=Qwen3.6-35B-A3B-UD-Q5_K_M.gguf
MODEL_NAME=Qwen3.6-35B-A3B-UD-Q5_K_M

# Local storage.
MODEL_DIR=./models/gguf
HF_CACHE_DIR=./hf-cache
RESULTS_DIR=./results
LOG_DIR=./logs
THIRD_PARTY_DIR=./third_party

# ik_llama.cpp checkout and build controls.
IK_LLAMA_REPO=https://github.com/ikawrakow/ik_llama.cpp
IK_LLAMA_REF=main
CUDA_VERSION=12.8.1
CMAKE_CUDA_ARCHITECTURES=75
IK_LLAMA_BUILD_DIR=./third_party/ik_llama.cpp/build-qwen36-2080ti
BUILD_BACKEND=local
BUILD_JOBS=8
LLAMA_CURL=OFF
LLAMA_SERVER_BIN=

# Serving defaults tuned for dual RTX 2080 Ti 22GB + NVLink.
HOST_PORT=8000
USE_DOCKER_RUNTIME=0
CUDA_VISIBLE_DEVICES=0,1
TENSOR_SPLIT=50,50
SPLIT_MODE=graph
N_GPU_LAYERS=999
N_PARALLEL=1
MAX_MODEL_LEN=131072
UBATCH=512
BATCH=2048
THREADS=4
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0
FLASH_ATTN=1
# JINJA=0 uses the template embedded in the GGUF metadata.
# Set JINJA=1 together with CHAT_TEMPLATE_FILE to force a custom external template.
JINJA=0
NO_CONTEXT_SHIFT=1
NO_MMAP=1
REASONING_FORMAT=none
REASONING_BUDGET=0
CHAT_TEMPLATE_ENABLE_THINKING=0
REASONING_TOKENS=none
MLA_USE=3
ATTENTION_MAX_BATCH=256
CHAT_TEMPLATE_FILE=./jinja/qwopus_v3_template.jinja
SAMPLING_TEMP=0.7
SAMPLING_TOP_P=0.8
SAMPLING_TOP_K=20
SAMPLING_MIN_P=0.0
SAMPLING_PRESENCE_PENALTY=1.5

# Benchmark defaults.
BENCHMARK_CONTEXTS=16384,32768,65536
BENCHMARK_MAX_NEW_TOKENS=256
BENCHMARK_RESERVE_TOKENS=1024
BENCHMARK_PROFILE=stable

# Cache helpers.
HF_HOME=./hf-cache
HF_HUB_ENABLE_HF_TRANSFER=1
HF_HUB_DISABLE_XET=1
HF_HUB_DISABLE_TELEMETRY=1
