# Required for Hugging Face downloads.
HF_TOKEN=replace_me

# Container image build inputs.
CUDA_VERSION=12.8.1
IK_LLAMA_REF=64234e3c4ea9c3cd2dd1a4f84c7da38e9607c747
LLAMA_CPP_REF=a279d0f0f4e746d1ef3429d8e9d02d2990b2daa7
CMAKE_CUDA_ARCHITECTURES=75
TRANSFORMERS_VERSION=5.3.0

# Server listen port.
HOST_PORT=8000

# Source inputs from the existing vLLM deployment.
BASE_MODEL_SOURCE=../CoPaw/models/base/CoPaw-Flash-9B
LORA_SOURCE=../CoPaw/models/lora/CoPaw-Flash-9B-DataAnalyst-LoRA

# Local outputs in this deployment folder.
MERGED_MODEL_DIR=./models/merged/CoPaw-Flash-9B-DataAnalyst-Merged
GGUF_DIR=./models/gguf
GGUF_BASENAME=CoPaw-Flash-9B-DataAnalyst-Merged
GGUF_OUTTYPE=f16
GGUF_QUANT=Q5_K_M
MODEL_FILE=./models/gguf/CoPaw-Flash-9B-DataAnalyst-Merged-q5_k_m.gguf
MODEL_NAME=CoPaw-Flash-9B-DataAnalyst-Merged
CHAT_TEMPLATE_FILE=./models/merged/CoPaw-Flash-9B-DataAnalyst-Merged/chat_template.jinja
HF_PUBLISH_REPO=replace_me

# Optional source repo ids used by pull_models.sh if local inputs are missing.
BASE_MODEL_REPO=agentscope-ai/CoPaw-Flash-9B
LORA_REPO=jason1966/CoPaw-Flash-9B-DataAnalyst-LoRA

# Serving defaults for 2x RTX 2080 Ti 22GB.
CUDA_VISIBLE_DEVICES=0,1
SPLIT_MODE=layer
TENSOR_SPLIT=1,1
N_GPU_LAYERS=999
N_PARALLEL=2
MAX_MODEL_LEN=262144
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0
FLASH_ATTN=1
JINJA=1
REASONING_FORMAT=deepseek
REASONING_BUDGET=0
CHAT_TEMPLATE_ENABLE_THINKING=0
NO_CONTEXT_SHIFT=1

# Cache controls.
HF_HUB_ENABLE_HF_TRANSFER=1
HF_HUB_DISABLE_XET=1
